/target
Cargo.lock
*.swp
.DS_Store

# Gas Town per-worktree agent context — generated locally, never commit.
# Auto-checkpoint hooks run `git add -A`-style commits; without this entry
# the file leaks into WIP commits and collides with the untracked copy in
# every other polecat worktree on checkout.
CLAUDE.local.md

# wasm-bindgen output for the web playground (generated by the build)
/web/playground/pkg/

# web playground dependencies and build output
/web/playground/node_modules/
/web/playground/dist/

# Gas Town (added by gt)
.runtime/
.claude/
.logs/
__pycache__/
state.json
CLAUDE.md

# Stray mesh/BREP exports produced by running examples from the repo root.
# Real gallery artifacts live under tools/mcp-server/examples/output/ and are
# committed there; these root-level ones are throwaway (of-2y4.2).
/*.stl
/*.step
/*.obj
