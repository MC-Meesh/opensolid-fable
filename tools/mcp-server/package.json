{
  "name": "opensolid-mcp-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server exposing the OpenSolid kernel as an agentic CAD API surface",
  "bin": {
    "opensolid-mcp": "src/server.js"
  },
  "scripts": {
